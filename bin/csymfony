#!/bin/bash

# shellcheck source=_common.sh
source "$(dirname "${BASH_SOURCE[0]}")/_common.sh"

GIT_USER_NAME=$(git config --global user.name 2>/dev/null || echo "Developer")
GIT_USER_EMAIL=$(git config --global user.email 2>/dev/null || echo "dev@localhost")

COMPOSER_HOME="${XDG_CACHE_HOME:-$HOME/.cache}/composer"
mkdir -p "$COMPOSER_HOME"

docker run --rm -it \
    -v "$(pwd)":/app \
    -v "$SCRIPT_DIR/../php/$VERSION/php.ini:/usr/local/etc/php/conf.d/custom.ini" \
    -v "$COMPOSER_HOME":/tmp/composer \
    -w /app \
    --network dev-net \
    --user "$(id -u):$(id -g)" \
    -e HOME=/tmp \
    -e COMPOSER_HOME=/tmp/composer \
    -e GIT_AUTHOR_NAME="$GIT_USER_NAME" \
    -e GIT_AUTHOR_EMAIL="$GIT_USER_EMAIL" \
    -e GIT_COMMITTER_NAME="$GIT_USER_NAME" \
    -e GIT_COMMITTER_EMAIL="$GIT_USER_EMAIL" \
    "php:$VERSION-dev" \
    symfony "$@"
